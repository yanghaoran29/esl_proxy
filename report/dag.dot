digraph TaskDAG {
    # Graph settings
    rankdir=TB;
    splines=ortho;
    nodesep=0.5;
    ranksep=0.8;
    bgcolor="#1a1a2e";
    fontname="Arial";
    fontsize=12;
    node [fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9];

