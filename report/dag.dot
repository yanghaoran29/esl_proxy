    # Legend
    subgraph cluster_legend {
        label="Legend";
        style=filled;
        color="#333333";
        fontsize=11;
        fontcolor=white;
        "legend_cube" [shape=box, style=filled, fillcolor="#ff9800", color="#ffb74d", width=0.3, height=0.2];
        "legend_cube_label" [shape=none, fontsize=10, fontcolor="#ff9800", label="CUBE (type 0)"];
        "legend_vector" [shape=ellipse, style=filled, fillcolor="#9c27b0", color="#ce93d8", width=0.3, height=0.2];
        "legend_vector_label" [shape=none, fontsize=10, fontcolor="#9c27b0", label="VECTOR (type 1)"];
        "legend_mix" [shape=diamond, style=filled, fillcolor="#00bcd4", color="#4dd0e1", width=0.3, height=0.2];
        "legend_mix_label" [shape=none, fontsize=10, fontcolor="#00bcd4", label="MIX (type 2)"];
        "legend_cube" -> "legend_cube_label" [style=invis];
        "legend_vector" -> "legend_vector_label" [style=invis];
        "legend_mix" -> "legend_mix_label" [style=invis];
    }
}